#!/bin/bash

# load required modules
module load cuda
module load gcc-native/12.3
module unload cray-mpich
module load mpich

# cmake requirements
mkdir -p build
cd ./build
cmake ..
make
cd ../assets
rm out.txt
cd ..

# Usage:
# Sweep mode:   ./test <filename> all
# Single mode:  ./test <filename> <BATCH_SIZE> <SEQ_LEN>

if [ -z "$1" ]; then
    echo "Usage:"
    echo "  Sweep mode:  $0 <filename_without_extension> all"
    echo "  Single mode: $0 <filename_without_extension> <BATCH_SIZE> <SEQ_LEN>"
    exit 1
fi

FILE=$1

# If second argument is "all", run full sweep
if [ "$2" == "all" ]; then

    BATCH_SIZES=(256 512 768 1024)
    SEQ_LENS=(128 256 512 1024)

    for BATCH in "${BATCH_SIZES[@]}"; do
        echo "Running with BATCH_SIZE=$BATCH"
        ./build/MultiBlockBPE ./assets/${FILE}.txt batch_size $BATCH
    done

    for SEQ in "${SEQ_LENS[@]}"; do
        echo "Running with SEQ_LEN=$SEQ"
        ./build/MultiBlockBPE ./assets/${FILE}.txt seq_len $SEQ
    done

# Otherwise, treat $2 and $3 as explicit inputs
else
    if [ -z "$3" ]; then
        echo "Error: In single mode you must provide both mode and value"
        echo "Usage: $0 <filename_without_extension> <\"batch_size\"/\"seq_len\"> <value>"
        exit 1
    fi

    MODE=$2
    VALUE=$3

    echo "Running mode=$MODE value=$VALUE"
    ./build/MultiBlockBPE ./assets/${FILE}.txt $MODE $VALUE
fi
